# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# Application Configuration
VITE_APP_URL=https://mdmcmusicads.com
VITE_APP_DOMAIN=mdmcmusicads.com
VITE_API_URL=https://mdmcmusicads.com/api

# Analytics & Monitoring
VITE_GA_MEASUREMENT_ID=G-your_ga_id
VITE_SENTRY_DSN=https://your_sentry_dsn

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true
VITE_ENABLE_DEV_TOOLS=false

# Rate Limiting (requests per minute)
VITE_RATE_LIMIT_ANONYMOUS=10
VITE_RATE_LIMIT_AUTHENTICATED=100

# Environment
NODE_ENV=development